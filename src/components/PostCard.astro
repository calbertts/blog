---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const { title, description, pubDate, cover, tags } = post.data;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  month: 'short', day: 'numeric', year: 'numeric'
});

const readingTime = Math.ceil(post.body.split(/\s+/).length / 200);
---

<article class:list={['post-card', { featured }]}>
  <a href={`/blog/${post.id}`} class="card-link">
    <div class="card-text">
      <h2 class="card-title">{title}</h2>
      <p class="card-desc">{description}</p>
      <div class="card-meta">
        <span class="meta-item">{readingTime} min read</span>
        <span class="meta-dot">·</span>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {tags.length > 0 && (
          <>
            <span class="meta-dot">·</span>
            {tags.slice(0,2).map(t => <span class="tag">{t}</span>)}
          </>
        )}
      </div>
    </div>
    {cover && (
      <div class="card-cover">
        <img src={cover} alt={title} loading="lazy" />
      </div>
    )}
  </a>
</article>

<style>
  .post-card {
    padding: 28px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .card-link {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
  }

  .card-text { flex: 1; min-width: 0; }

  .card-title {
    font-family: var(--font-ui);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: 6px;
    transition: color 0.15s;
  }

  .featured .card-title {
    font-size: 1.75rem;
  }

  .card-link:hover .card-title { color: #333; }

  .card-desc {
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    color: var(--color-text-light);
    line-height: 1.55;
    margin-bottom: 10px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured .card-desc {
    font-size: 1rem;
    -webkit-line-clamp: 3;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 5px;
    flex-wrap: wrap;
  }

  .meta-item, time {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: var(--color-text-lighter);
  }

  .meta-dot {
    color: var(--color-text-lighter);
    font-size: 0.8125rem;
  }

  .tag {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--color-text-light);
    background: var(--color-tag-bg);
    padding: 2px 8px;
    border-radius: 100px;
  }

  .card-cover {
    flex-shrink: 0;
    width: 140px;
    height: 93px;
    border-radius: 3px;
    overflow: hidden;
    background: var(--color-hover);
  }

  .featured .card-cover {
    width: 180px;
    height: 120px;
  }

  .card-cover img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .card-link:hover .card-cover img { transform: scale(1.04); }

  @media (max-width: 600px) {
    .card-cover { width: 88px; height: 58px; }
    .card-title { font-size: 1.0625rem; }
    .featured .card-title { font-size: 1.25rem; }
  }
</style>
