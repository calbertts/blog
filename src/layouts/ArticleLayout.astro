---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, cover, tags } = post.data;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});

const readingTime = Math.ceil(post.body.split(/\s+/).length / 200);
const slug = post.id;
---

<BaseLayout
  title={`${title} — Carlos Alberto`}
  description={description}
  image={cover}
  pubDate={pubDate}
  isArticle={true}
>
  <Header />

  <main class="article-main">
    <article class="article">

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="article-tags">
          {tags.map(t => <span class="tag">{t}</span>)}
        </div>
      )}

      <!-- Título grande estilo Medium -->
      <h1 class="article-title">{title}</h1>

      <!-- Descripción / subtítulo -->
      <p class="article-subtitle">{description}</p>

      <!-- Meta -->
      <div class="article-meta">
        <span class="meta-reading">{readingTime} min read</span>
        <span class="meta-sep">·</span>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {updatedDate && (
          <>
            <span class="meta-sep">·</span>
            <span>Updated {updatedDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
          </>
        )}
      </div>

      <hr class="divider" />

      <!-- Cover -->
      {cover && (
        <div class="article-cover">
          <img src={cover} alt={title} />
        </div>
      )}

      <!-- Cuerpo del artículo -->
      <div class="prose">
        <slot />
      </div>

      <!-- Likes -->
      <div class="likes-section">
        <button class="likes-btn" id="likes-btn" data-slug={slug} aria-label="Me gusta">
          <span class="likes-icon" id="likes-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </span>
          <span class="likes-count" id="likes-count">–</span>
        </button>
      </div>

    </article>

    <div class="back-wrap">
      <a href="/" class="back-link">← All posts</a>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  const API = 'https://api.blog.calbertts.com';

  async function initLikes() {
    const btn = document.getElementById('likes-btn') as HTMLButtonElement;
    const countEl = document.getElementById('likes-count') as HTMLSpanElement;
    const iconEl = document.getElementById('likes-icon') as HTMLSpanElement;
    if (!btn) return;

    const slug = btn.dataset.slug!;
    const storageKey = `liked_${slug}`;
    const liked = localStorage.getItem(storageKey) === '1';

    // Cargar conteo
    try {
      const res = await fetch(`${API}/likes/${slug}`);
      const data = await res.json();
      countEl.textContent = data.count;
    } catch {
      countEl.textContent = '0';
    }

    // Estado visual inicial
    if (liked) btn.classList.add('liked');

    btn.addEventListener('click', async () => {
      const isLiked = btn.classList.contains('liked');
      btn.classList.toggle('liked');
      localStorage.setItem(storageKey, isLiked ? '0' : '1');

      try {
        const res = await fetch(`${API}/likes/${slug}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: isLiked ? 'unlike' : 'like' }),
        });
        const data = await res.json();
        countEl.textContent = data.count;
      } catch {
        // revertir si falla
        btn.classList.toggle('liked');
        localStorage.setItem(storageKey, isLiked ? '1' : '0');
      }
    });
  }

  initLikes();
</script>

<style>
  .article-main {
    padding: 52px 24px 0;
  }

  .article {
    max-width: var(--reading-width);
    margin: 0 auto;
  }

  /* Tags */
  .article-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .tag {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-light);
    background: var(--color-tag-bg);
    padding: 3px 12px;
    border-radius: 100px;
  }

  /* Título — grande y bold como Medium */
  .article-title {
    font-family: var(--font-ui);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: 16px;
  }

  /* Subtítulo / descripción — serif, suave */
  .article-subtitle {
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: 20px;
    font-style: italic;
  }

  /* Meta */
  .article-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .meta-reading, .article-meta time, .article-meta span {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: var(--color-text-lighter);
  }

  .meta-sep { color: var(--color-border); }

  .divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 0 0 40px;
  }

  /* Cover */
  .article-cover {
    margin-bottom: 48px;
    border-radius: 4px;
    overflow: hidden;
  }

  .article-cover img {
    width: 100%;
    max-height: 520px;
    object-fit: cover;
  }

  /* Prose — Lora para cuerpo del artículo */
  .prose {
    font-family: var(--font-body);
    font-size: 1.1875rem;
    line-height: 1.85;
    color: #1a1a1a;
  }

  .prose :global(h2) {
    font-family: var(--font-ui);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 2.5em 0 0.75em;
    line-height: 1.25;
    color: var(--color-text);
  }

  .prose :global(h3) {
    font-family: var(--font-ui);
    font-size: 1.25rem;
    font-weight: 600;
    margin: 2em 0 0.5em;
    line-height: 1.3;
    color: var(--color-text);
  }

  .prose :global(p) { margin-bottom: 1.6em; }

  .prose :global(a) {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: #ccc;
    transition: text-decoration-color 0.15s;
  }

  .prose :global(a:hover) { text-decoration-color: var(--color-text); }

  .prose :global(strong) { font-weight: 700; }

  .prose :global(em) { font-style: italic; }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-text);
    margin: 2em 0;
    padding: 2px 0 2px 28px;
    font-style: italic;
    font-size: 1.3rem;
    color: var(--color-text-light);
    line-height: 1.65;
  }

  .prose :global(blockquote p) { margin-bottom: 0; }

  .prose :global(ul), .prose :global(ol) {
    margin: 0.5em 0 1.5em 1.75em;
  }

  .prose :global(li) { margin-bottom: 0.5em; }

  .prose :global(hr) {
    border: none;
    text-align: center;
    margin: 3em 0;
  }

  .prose :global(hr::after) {
    content: '· · ·';
    font-size: 1.25rem;
    color: var(--color-text-lighter);
    letter-spacing: 0.5em;
  }

  .prose :global(code) {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.875em;
    background: #f5f5f5;
    padding: 2px 6px;
    border-radius: 3px;
    color: var(--color-text);
  }

  .prose :global(pre) {
    background: #1c1c1e;
    color: #e8e8e8;
    padding: 24px;
    border-radius: 6px;
    overflow-x: auto;
    margin: 2em 0;
    font-size: 0.875rem;
    line-height: 1.7;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  .prose :global(img) {
    border-radius: 3px;
    margin: 2em auto;
  }

  .prose :global(figcaption) {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--color-text-lighter);
    text-align: center;
    margin-top: 8px;
  }

  /* ── Likes ── */
  .likes-section {
    margin-top: 56px;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: center;
  }

  .likes-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-lighter);
    transition: color 0.2s, transform 0.15s;
    padding: 8px 16px;
  }

  .likes-btn:hover {
    color: #e0245e;
    transform: scale(1.05);
  }

  .likes-btn.liked {
    color: #e0245e;
  }

  .likes-btn.liked .likes-icon svg {
    fill: #e0245e;
    stroke: #e0245e;
  }

  .likes-btn:active { transform: scale(0.95); }

  .likes-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s;
  }

  .likes-btn:hover .likes-icon { transform: scale(1.15); }

  .likes-count {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    font-weight: 500;
  }

  /* Back */
  .back-wrap {
    max-width: var(--reading-width);
    margin: 48px auto 0;
    padding: 28px 0;
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    color: var(--color-text-light);
    transition: color 0.15s;
  }

  .back-link:hover { color: var(--color-text); }
</style>
