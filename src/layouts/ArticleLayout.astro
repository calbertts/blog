---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, cover, tags } = post.data;

const formattedDate = pubDate.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const readingTime = Math.ceil(post.body.split(/\s+/).length / 200);
---

<BaseLayout
  title={`${title} — Carlos Alberto`}
  description={description}
  image={cover}
  pubDate={pubDate}
  isArticle={true}
>
  <Header />

  <main class="article-main">
    <article class="article">

      <header class="article-header">
        {tags.length > 0 && (
          <div class="article-tags">
            {tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        )}

        <h1 class="article-title">{title}</h1>
        <p class="article-description">{description}</p>

        <div class="article-meta">
          <time datetime={pubDate.toISOString()} class="article-date">{formattedDate}</time>
          <span class="meta-separator">·</span>
          <span class="reading-time">{readingTime} min de lectura</span>
          {updatedDate && (
            <>
              <span class="meta-separator">·</span>
              <span class="updated-date">
                Actualizado: {updatedDate.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
            </>
          )}
        </div>
      </header>

      {cover && (
        <div class="article-cover">
          <img src={cover} alt={title} />
        </div>
      )}

      <div class="article-body prose">
        <slot />
      </div>

    </article>

    <nav class="article-nav">
      <a href="/" class="back-link">
        ← Todos los artículos
      </a>
    </nav>
  </main>

  <Footer />
</BaseLayout>

<style>
  .article-main {
    padding: 48px 24px 0;
  }

  .article {
    max-width: var(--reading-width);
    margin: 0 auto;
  }

  /* ── Header ── */
  .article-header {
    margin-bottom: 40px;
  }

  .article-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .tag {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-accent);
    background: #e8f5e9;
    padding: 3px 12px;
    border-radius: 100px;
  }

  .article-title {
    font-family: var(--font-body);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: 16px;
  }

  .article-description {
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--color-text-light);
    line-height: 1.5;
    margin-bottom: 20px;
    font-style: italic;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--color-border);
  }

  .article-date,
  .reading-time,
  .updated-date {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--color-text-lighter);
  }

  .meta-separator {
    color: var(--color-text-lighter);
  }

  /* ── Cover ── */
  .article-cover {
    margin: 40px 0;
    border-radius: 6px;
    overflow: hidden;
    max-height: 480px;
  }

  .article-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Body (prose) ── */
  .prose {
    font-family: var(--font-body);
    font-size: 1.1875rem;
    line-height: 1.8;
    color: var(--color-text);
    padding-top: 8px;
  }

  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 2em 0 0.75em;
    line-height: 1.3;
  }

  .prose :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 1.75em 0 0.5em;
    line-height: 1.3;
  }

  .prose :global(h4) {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 1.5em 0 0.5em;
  }

  .prose :global(p) {
    margin-bottom: 1.5em;
  }

  .prose :global(a) {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-border);
    transition: text-decoration-color 0.15s ease;
  }

  .prose :global(a:hover) {
    text-decoration-color: var(--color-text);
  }

  .prose :global(strong) {
    font-weight: 700;
    color: var(--color-text);
  }

  .prose :global(em) {
    font-style: italic;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-text);
    margin: 2em 0;
    padding: 4px 0 4px 24px;
    font-style: italic;
    font-size: 1.25rem;
    color: var(--color-text-light);
    line-height: 1.6;
  }

  .prose :global(blockquote p) {
    margin-bottom: 0;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 1em 0 1.5em 1.5em;
  }

  .prose :global(li) {
    margin-bottom: 0.5em;
    line-height: 1.7;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 3em auto;
    width: 40%;
  }

  .prose :global(code) {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.875em;
    background: var(--color-hover);
    padding: 2px 6px;
    border-radius: 3px;
    color: var(--color-text);
  }

  .prose :global(pre) {
    background: #1a1a1a;
    color: #e8e8e8;
    padding: 24px;
    border-radius: 6px;
    overflow-x: auto;
    margin: 2em 0;
    font-size: 0.875rem;
    line-height: 1.7;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  .prose :global(img) {
    border-radius: 4px;
    margin: 2em auto;
  }

  .prose :global(figure) {
    margin: 2em 0;
  }

  .prose :global(figcaption) {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--color-text-lighter);
    text-align: center;
    margin-top: 8px;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2em 0;
    font-size: 0.9375rem;
  }

  .prose :global(th),
  .prose :global(td) {
    padding: 10px 16px;
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .prose :global(th) {
    font-family: var(--font-ui);
    font-weight: 600;
    background: var(--color-hover);
  }

  /* ── Back nav ── */
  .article-nav {
    max-width: var(--reading-width);
    margin: 48px auto 0;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    color: var(--color-text-light);
    transition: color 0.15s ease;
  }

  .back-link:hover {
    color: var(--color-text);
  }
</style>
